# frontend/.env.example — copy to frontend/.env.local to override.
#
# Vite inlines these into the bundle at build time (only vars prefixed
# with VITE_ are exposed to client code — anything else stays server-side).

# Where the SPA expects the API to live. Resolution order in src/api/client.ts:
#   1. This var (if set) wins.
#   2. Vite dev → http://localhost:8000 (the FastAPI dev server).
#   3. Production build → '' (same origin via nginx proxy).
# VITE_API_BASE_URL=http://localhost:8000
