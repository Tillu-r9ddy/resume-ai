# backend/.env.example — copy to backend/.env to override defaults.
#
# Pydantic-settings reads these on app startup. All vars use the
# RESUME_AI_ prefix so they're easy to grep for and don't collide with
# anything else on a developer's machine.

# Free-form label that shows up in /api/health. Useful for "am I hitting
# staging or local right now?". Defaults to "local" if unset.
RESUME_AI_ENV_NAME=local

# JSON-encoded list of allowed CORS origins. Defaults cover Vite dev.
# RESUME_AI_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Chat provider — "echo" (default, no extra setup) or "ollama" (requires
# Ollama running locally). See app/services/llm.py.
# RESUME_AI_LLM_PROVIDER=echo

# Only used when llm_provider=ollama.
# RESUME_AI_OLLAMA_HOST=http://localhost:11434
# RESUME_AI_OLLAMA_MODEL=llama3.1:8b
