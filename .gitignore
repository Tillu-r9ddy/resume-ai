# ─────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js

# ─────────────────────────────────────────────────────────────────────────────
# Build outputs
# WHY: Generated by `npm run build`. Never commit — recruiters lose trust when
# they see `dist/` in a repo; it implies the dev doesn't understand build vs source.
# ─────────────────────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.vite/
.turbo/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# Coverage & test artifacts
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ─────────────────────────────────────────────────────────────────────────────
# Environment files
# WHY: .env.* often holds API keys / DB URLs. Only commit .env.example as a
# template — never the populated ones. This is the #1 source of leaked secrets.
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Editor / OS junk
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Python (backend will live here later)
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────────────
# Husky internals
# ─────────────────────────────────────────────────────────────────────────────
.husky/_/

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code local state
# WHY: Per-developer agent settings, hooks, and transcripts. Not project source.
# Teammates set up their own .claude/ when they install Claude Code.
# ─────────────────────────────────────────────────────────────────────────────
.claude/
